# --- 推荐：经 LiteLLM Proxy（与 docker-compose.litellm.yml 联调）---
# LITELLM_API_KEY 必须与 infra/litellm/.env 里的 LITELLM_MASTER_KEY 一致
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_API_KEY=sk-canonweave-litellm-dev

# --- 直连上游（选模型「直连」或默认新会话用 deepseek 时需填对应 Key）---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# 设为 1 时强制使用内置 mock 流，不调用外部 API（无 Key 本地演示）
# CW_CHAT_MOCK=1

# --- MCP 掷骰（须先 npm run build:mcp-dice）---
# CW_USE_MCP_DICE=1
# CW_MCP_DICE_SERVER=../../mcp-servers/dice-roller/dist/index.js

# world_reader / world_writer MCP 入口（可选覆盖默认路径）
# CW_MCP_WORLD_SERVER=../../mcp-servers/world-tools/dist/index.js

# 酒馆对话中挂载 Agent 工具（掷骰 / 世界书读写，需模型支持 function calling）
# CW_AGENT_MCP=1

# ReAct 认知框架：系统提示要求 Thought → Action → Observation；须与 CW_AGENT_MCP 同开
# CW_REACT_FRAMEWORK=1

# --- 分层记忆（共享池 + NPC 私域 + 全局洞察表 cw_insights）---
# CW_LAYERED_MEMORY=1
# 对话线也跑监督者抽取（可选，多一次调用）
# CW_LAYERED_MEMORY_DIALOGUE_EXTRACT=1
# CW_LAYERED_MEMORY_MAX_GOALS=8
# CW_LAYERED_MEMORY_MAX_PRIVATE=14
# CW_LAYERED_MEMORY_INSIGHT_LIMIT=10

# --- 动态扮演引擎（酒馆多 Agent 运行时，见 docs/dynamic-rp-engine.md）---
# CW_DYNAMIC_RP_ENGINE=1
# 意图：hybrid=规则未命中时再模型分类；full=每轮模型分类
# CW_DRE_INTENT_LLM=1
# CW_DRE_INTENT_LLM=full
# NPC 后台广播轮数（1=单轮并行，2~4=多轮 A2A）
# CW_DRE_A2A_ROUNDS=2
# 可选：总线镜像 + 下一拍可读上一拍总线（多实例需共享此 URL）
# CW_DRE_A2A_REDIS_URL=redis://127.0.0.1:6379

# DRE-3：工作记忆摄取 + 事实冲突检测（动作线写入 session_state_json.dreMemory）
# CW_DRE_MEMORY=1
# CW_DRE_MEMORY_MAX_ENTRIES=28
# CW_DRE_MEMORY_MAX_CONFLICTS=20

# --- Mem0 Platform API（长期记忆；Next 内使用 MemoryClient，勿直接 import mem0ai/oss）---
# CW_MEM0=1
# CW_MEM0_PLATFORM_API_KEY=
# 自托管 REST 时填写根 URL（默认可不填 = https://api.mem0.ai）
# CW_MEM0_PLATFORM_HOST=
# CW_MEM0_SCOPE=thread
# CW_MEM0_SEARCH_LIMIT=8

# DRE-4：绑定世界版本时，按本回合文本选取 Canonical 实体锚点
# CW_DRE_WORLD_ENTITIES=1
# CW_DRE_ENTITY_LLM=1
# CW_DRE_WORLD_ENTITY_CATALOG_MAX=150
# CW_DRE_WORLD_ENTITY_PICK_MAX=10
